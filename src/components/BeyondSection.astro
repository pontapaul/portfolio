---
import type { Locale } from '../i18n';
import { t } from '../i18n';

interface Props {
  lang?: Locale;
}

const { lang = 'it' } = Astro.props;

const items = [
  {
    icon: "🏐",
    title: t(lang, 'beyond.volleyball.title'),
    body: t(lang, 'beyond.volleyball.body'),
  },
  {
    icon: "🖥️",
    title: t(lang, 'beyond.selfhosting.title'),
    body: t(lang, 'beyond.selfhosting.body'),
  },
  {
    icon: "📐",
    title: t(lang, 'beyond.obsessions.title'),
    body: t(lang, 'beyond.obsessions.body'),
  },
  {
    icon: "🔄",
    title: t(lang, 'beyond.iteration.title'),
    body: t(lang, 'beyond.iteration.body'),
  },
];
---

<section class="mt-24">
  <h2 class="text-muted text-sm font-mono uppercase tracking-widest mb-3">{t(lang, 'beyond.title')}</h2>
  <p class="text-text/70 text-base mb-10 max-w-xl leading-relaxed">
    {t(lang, 'beyond.subtitle')}
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {items.map(item => (
      <div class="bg-surface border border-border rounded-lg p-6 hover:-translate-y-0.5 transition-transform duration-200">
        <div class="text-2xl mb-3">{item.icon}</div>
        <h3 class="text-base font-semibold text-text mb-2">{item.title}</h3>
        <p class="text-muted text-sm leading-relaxed">{item.body}</p>
      </div>
    ))}
  </div>
</section>
