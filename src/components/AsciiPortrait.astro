---
---
<canvas id="ascii-portrait" class="select-none block" aria-hidden="true"></canvas>
<script>
  function drawPortrait() {
    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.src = '/assets/nobgwhite.jpg';
    img.onload = () => {
      const canvas = document.getElementById('ascii-portrait') as HTMLCanvasElement;
      if (!canvas) return;
      const ctx = canvas.getContext('2d')!;

      // Detect current theme
      const isLight = document.documentElement.getAttribute('data-theme') === 'light';

      // Read accent color from CSS variable
      const style = getComputedStyle(document.documentElement);
      const accentHex = style.getPropertyValue('--color-accent').trim();
      const r0 = parseInt(accentHex.slice(1, 3), 16);
      const g0 = parseInt(accentHex.slice(3, 5), 16);
      const b0 = parseInt(accentHex.slice(5, 7), 16);
      const accentRgb = `${r0},${g0},${b0}`;

      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const cellSize = vw < 768 ? 3 : vw < 1024 ? 4 : 5;
      const gap = cellSize === 3 ? 0.5 : 1;

      canvas.width = vw;
      canvas.height = vh;

      const vpRatio = vw / vh;
      const imgAspect = img.width / img.height;

      // Dynamic crop top: only on landscape, mobile gets no crop
      const cropPercent = vpRatio >= 1 ? Math.min(0.20, Math.max(0.05, (vpRatio - 0.5) * 0.15)) : 0;
      const cropTop = Math.floor(img.height * cropPercent);
      const srcH = img.height - cropTop;
      const croppedAspect = img.width / srcH;

      // Max container width for image content (like Bootstrap container)
      const maxContentWidth = 1400;

      let drawW: number, drawH: number, imgStartCol: number;

      if (vpRatio < 1) {
        // Mobile portrait: fill height, center horizontally
        drawH = vh;
        drawW = Math.floor(drawH * croppedAspect);
        const imgCols = Math.floor(drawW / cellSize);
        const totalCols = Math.ceil(vw / cellSize);
        // Slightly right of center
        imgStartCol = Math.floor((totalCols - imgCols) / 2) + Math.floor(totalCols * 0.08);
      } else {
        let imgScale: number;
        if (vw < 1024) {
          imgScale = 0.75;       // tablet: 25% padding
        } else {
          imgScale = 0.80;       // desktop: 20% padding
        }
        drawW = Math.min(Math.floor(vw * imgScale), Math.floor(maxContentWidth * imgScale));
        drawH = Math.floor(drawW / croppedAspect);
        const imgCols = Math.floor(drawW / cellSize);
        // Image starts from the right edge
        imgStartCol = Math.ceil(vw / cellSize) - imgCols;
      }

      const imgCols = Math.floor(drawW / cellSize);
      const imgRows = Math.floor(drawH / cellSize);

      // Sample cropped image at grid resolution
      const off = document.createElement('canvas');
      off.width = imgCols;
      off.height = imgRows;
      const offCtx = off.getContext('2d')!;
      offCtx.drawImage(img, 0, cropTop, img.width, srcH, 0, 0, imgCols, imgRows);
      const d = offCtx.getImageData(0, 0, imgCols, imgRows).data;

      const totalCols = Math.ceil(vw / cellSize);
      const totalRows = Math.ceil(vh / cellSize);

      ctx.clearRect(0, 0, vw, vh);

      for (let y = 0; y < totalRows; y++) {
        const py = y * cellSize;
        for (let x = 0; x < totalCols; x++) {
          const px = x * cellSize;

          const imgX = x - imgStartCol;
          const imgY = y;

          if (imgX >= 0 && imgX < imgCols && imgY >= 0 && imgY < imgRows) {
            const i = (imgY * imgCols + imgX) * 4;
            const r = d[i], g = d[i + 1], b = d[i + 2];
            const lum = 0.299 * r + 0.587 * g + 0.114 * b;
            // Dark theme: bright pixels → opaque (face is silhouette in colored field)
            // Light theme: invert — dark pixels → opaque (face stands out on light bg)
            const opacity = isLight
              ? 0.05 + ((255 - lum) / 255) * 0.70
              : 0.05 + (lum / 255) * 0.70;

            if (opacity < 0.15) {
              if (Math.random() < 0.04) {
                ctx.fillStyle = `rgba(${accentRgb},${(0.05 + Math.random() * 0.1).toFixed(2)})`;
                ctx.fillRect(px, py, cellSize - gap, cellSize - gap);
              }
              continue;
            }

            ctx.fillStyle = `rgba(${accentRgb},${opacity.toFixed(2)})`;
            ctx.fillRect(px, py, cellSize - gap, cellSize - gap);
          } else {
            // Outside image — fill to match: solid in dark, subtle in light
            const wallOpacity = isLight ? 0.08 : 0.75;
            ctx.fillStyle = `rgba(${accentRgb},${wallOpacity})`;
            ctx.fillRect(px, py, cellSize - gap, cellSize - gap);
          }
        }
      }
    };
  }

  drawPortrait();

  // Redraw when theme changes
  const observer = new MutationObserver((mutations) => {
    for (const m of mutations) {
      if (m.attributeName === 'data-theme') {
        drawPortrait();
        break;
      }
    }
  });
  observer.observe(document.documentElement, { attributes: true });
</script>
