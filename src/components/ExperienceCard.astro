---
interface Props {
  role: string;
  company: string;
  location: string;
  period: string;
  description: string;
  tags?: string[];
}

const { role, company, location, period, description, tags = [] } = Astro.props;
---
<div class="border-l-2 border-[var(--color-accent)] pl-5 py-1">
  <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-1">
    <h3 class="text-lg font-bold text-[var(--color-text)]">{role}</h3>
    <span class="text-sm text-[var(--color-muted)] shrink-0">{period}</span>
  </div>
  <p class="text-sm text-[var(--color-accent)] mb-3">
    {company} · <span class="text-[var(--color-muted)]">{location}</span>
  </p>
  <p class="text-[var(--color-text)] leading-relaxed mb-4">{description}</p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {tags.map(tag => (
        <span class="text-xs font-mono border border-[var(--color-accent)]/40 text-[var(--color-accent)] px-2 py-0.5 rounded">
          {tag}
        </span>
      ))}
    </div>
  )}
</div>
