---
import type { Locale } from '../i18n';
import { t } from '../i18n';

interface Props {
  src?: string;
  alt: string;
  class?: string;
  lazy?: boolean;
  lang?: Locale;
}

const { src, alt, class: className = '', lazy = true, lang = 'it' } = Astro.props;
const hasCover = !!src;
---

{hasCover ? (
  <img
    src={src}
    alt={alt}
    class={className}
    loading={lazy ? 'lazy' : 'eager'}
  />
) : (
  <div class:list={['flex items-center justify-center bg-[#1a1a1a] border border-[var(--color-border)]', className]}>
    <div class="text-center">
      <span class="block text-4xl mb-2 text-accent opacity-40 font-mono">&lt;/&gt;</span>
      <span class="block text-xs font-mono text-muted opacity-50">{t(lang, 'cover.fallback')}</span>
    </div>
  </div>
)}
