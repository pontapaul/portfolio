---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Portfolio — Paolo Pontarollo">
  <section class="py-8">
    <h1 class="text-4xl font-bold mb-2">Portfolio</h1>
    <p class="text-[var(--color-muted)] mb-10">Esperienza lavorativa e competenze tecniche.</p>
  </section>

  <section class="mt-4">
    <h2 class="text-2xl font-bold mb-6">Esperienza</h2>
    <p class="text-[var(--color-muted)]">In arrivo...</p>
  </section>

  <section class="mt-12">
    <h2 class="text-2xl font-bold mb-6">Competenze</h2>
    <p class="text-[var(--color-muted)]">In arrivo...</p>
  </section>
</BaseLayout>
