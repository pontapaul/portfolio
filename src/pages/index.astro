---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Paolo Pontarollo — Full Stack Developer">
  <section class="py-12">
    <p class="text-[var(--color-muted)] mb-2 text-sm uppercase tracking-widest">Ciao, sono</p>
    <h1 class="text-5xl font-bold mb-4 leading-tight">
      Paolo<br /><span class="text-[var(--color-accent)]">Pontarollo</span>
    </h1>
    <p class="text-[var(--color-muted)] text-lg max-w-xl">
      Full Stack Developer — Laravel, Vue.js, TypeScript. Basato a Bassano del Grappa.
    </p>
  </section>

  <section class="mt-12">
    <h2 class="text-2xl font-bold mb-6">Progetti</h2>
    <p class="text-[var(--color-muted)]">In arrivo...</p>
  </section>
</BaseLayout>
