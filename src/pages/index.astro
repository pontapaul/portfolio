---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ProjectPreview from '../components/ProjectPreview.astro';
import { projects } from '../data/projects.ts';

const featured = projects.filter(p => p.featured);
const minor = projects.filter(p => !p.featured);
---
<BaseLayout title="Paolo Pontarollo — Full Stack Developer">
  <HeroSection slot="fullwidth" />

  <!-- Featured projects -->
  <section class="mt-16">
    <h2 class="text-muted text-sm font-mono uppercase tracking-widest mb-8">Progetti in evidenza</h2>
    {featured.map(p => (
      <ProjectPreview
        slug={p.slug}
        title={p.title}
        subtitle={p.subtitle}
        tags={p.tags}
        coverImage={p.coverImage ?? ''}
        wip={p.wip}
      />
    ))}
    <div class="pt-6">
      <a href="/projects" class="text-sm text-accent border border-accent/30 px-4 py-2 rounded hover:bg-accent/10 transition-colors font-mono">
        Tutti i progetti →
      </a>
    </div>
  </section>
</BaseLayout>
