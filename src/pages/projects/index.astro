---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../data/projects.ts';

const featured = projects.filter(p => p.featured);
const others = projects.filter(p => !p.featured);
---
<BaseLayout title="Progetti — Paolo Pontarollo">
  <section class="py-8">
    <h1 class="text-4xl font-bold mb-2">Progetti</h1>
    <p class="text-muted text-base">Archivio completo dei miei lavori — personali, open source e sperimentali.</p>
  </section>

  <!-- Featured projects -->
  <section class="mt-4">
    <p class="text-muted text-xs font-mono uppercase tracking-widest mb-6">Progetti principali</p>
    <div class="flex flex-col gap-0">
      {featured.map(p => (
        <a href={`/projects/${p.slug}`} class="group block border-b border-border py-8 hover:border-accent/30 transition-colors">
          <div class="flex flex-col md:flex-row md:items-start gap-6">
            <!-- Left: meta + title + description -->
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap gap-2 mb-3">
                {p.tags.map(tag => (
                  <span class="text-xs font-mono text-accent border border-accent/30 px-2 py-0.5 rounded">{tag}</span>
                ))}
                {p.wip && (
                  <span class="text-xs font-mono text-accent border border-accent/30 px-2 py-0.5 rounded">WIP</span>
                )}
              </div>
              <h2 class="text-2xl md:text-3xl font-bold text-text group-hover:text-accent transition-colors">
                {p.title}
              </h2>
              <p class="text-muted mt-1 text-sm">{p.subtitle}</p>
              <p class="text-text/80 mt-3 text-sm leading-relaxed">{p.description}</p>
              <span class="inline-block mt-4 text-xs font-mono text-accent">Scopri di più →</span>
            </div>
            <!-- Right: cover image -->
            {p.coverImage && (
              <div class="md:w-2/5 aspect-video overflow-hidden rounded-lg flex-shrink-0">
                <img
                  src={p.coverImage}
                  alt={p.title}
                  class="w-full h-full object-cover group-hover:scale-105 group-hover:brightness-110 transition-transform duration-300"
                  loading="lazy"
                />
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Other projects -->
  {others.length > 0 && (
    <section class="mt-12">
      <p class="text-muted text-xs font-mono uppercase tracking-widest mb-6">Altri lavori</p>
      <div class="flex flex-col gap-4">
        {others.map(p => (
          <div class="bg-[#1a1a1a] border border-border rounded-lg p-5 hover:border-accent/30 transition-colors">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  <span class="font-medium text-text">{p.title}</span>
                  {p.wip && (
                    <span class="text-xs font-mono text-accent border border-accent/30 px-2 py-0.5 rounded">WIP</span>
                  )}
                </div>
                <p class="text-muted text-sm mb-2">{p.subtitle}</p>
                <p class="text-text/70 text-sm leading-relaxed mb-3">{p.description}</p>
                <div class="flex flex-wrap gap-2">
                  {p.tags.map(tag => (
                    <span class="text-xs font-mono text-accent border border-accent/30 px-2 py-0.5 rounded">{tag}</span>
                  ))}
                </div>
              </div>
              <div class="flex flex-col gap-2 items-end flex-shrink-0">
                {p.repoUrl && (
                  <a href={p.repoUrl} target="_blank" rel="noopener noreferrer" class="text-muted hover:text-accent transition-colors text-sm font-mono whitespace-nowrap">↗ GitHub</a>
                )}
                {p.liveUrl && p.liveUrl !== '/' && (
                  <a href={p.liveUrl} target="_blank" rel="noopener noreferrer" class="text-muted hover:text-accent transition-colors text-sm font-mono whitespace-nowrap">↗ Live</a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
