---
import ProjectLayout from '../../layouts/ProjectLayout.astro';
---
<ProjectLayout
  title="volleyball.coach"
  subtitle="Suite di strumenti per allenatori di pallavolo"
  tags={["WIP"]}
  coverImage="/assets/projects/volleyball-coach/cover.svg"
  wip={true}
>
  <section class="space-y-8">
    <div>
      <h2 class="text-xl font-bold mb-2 text-[var(--color-accent)]">L'idea</h2>
      <p class="text-[var(--color-text)] leading-relaxed">
        Una suite di strumenti digitali pensata per gli allenatori di pallavolo, nata dall'esperienza diretta
        sul campo dal 2019. Gli strumenti per allenatori esistono, ma sono spesso costosi, rigidi o progettati
        per il professionismo — non per chi allena una squadra amatoriale o giovanile nel tempo libero.
      </p>
    </div>

    <div>
      <h2 class="text-xl font-bold mb-2 text-[var(--color-accent)]">Strumenti previsti</h2>
      <ul class="space-y-2 text-[var(--color-text)]">
        <li class="flex items-start gap-2">
          <span class="text-[var(--color-accent)] mt-0.5">→</span>
          <span><strong>Gestione rosa</strong> — anagrafica atleti, ruoli, presenze agli allenamenti</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-[var(--color-accent)] mt-0.5">→</span>
          <span><strong>Statistiche partite</strong> — raccolta dati in-game, grafici post-partita</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-[var(--color-accent)] mt-0.5">→</span>
          <span><strong>Pianificazione allenamenti</strong> — libreria di esercizi, costruzione sessioni</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-[var(--color-accent)] mt-0.5">→</span>
          <span><strong>Schede tecniche</strong> — note su avversari, schemi di gioco</span>
        </li>
      </ul>
    </div>

    <div class="border border-dashed border-[var(--color-border)] rounded-lg p-6 text-center">
      <p class="text-2xl mb-3">🏐</p>
      <p class="text-[var(--color-muted)] text-sm font-mono mb-1">stato attuale</p>
      <p class="text-[var(--color-accent)] font-bold text-lg">In sviluppo attivo</p>
      <p class="text-[var(--color-muted)] text-sm mt-2">
        Il progetto è in costruzione. Torno presto con qualcosa di concreto.
      </p>
    </div>
  </section>
</ProjectLayout>
